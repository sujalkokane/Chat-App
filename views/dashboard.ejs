<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root{
            --ink:#171923;
            --panel:#1b1e2b;
            --panel-2:#22263a;
            --bg:#f3f4f8;
            --card:#ffffff;
            --line:#e9eaf2;
            --muted:#8b8fa3;
            --accent:#5b6bf6;
            --accent-2:#ff7a5c;
            --accent-soft:#eef0fe;
            --ok:#2fbf85;
            --radius:16px;
        }

        *{ margin:0; padding:0; box-sizing:border-box; }

        body{
            background:var(--bg);
            font-family:'Inter',sans-serif;
            color:var(--ink);
            overflow-x:hidden;
            font-size:14px;
        }

        h1,h2,h3,h4{ font-family:'Space Grotesk',sans-serif; letter-spacing:-0.01em; }

        /* ---------- Sidebar ---------- */
        .sidebar{
            width:196px;
            height:100vh;
            position:fixed;
            left:0; top:0;
            background:var(--panel);
            color:#fff;
            display:flex;
            flex-direction:column;
            transition:margin-left .25s ease;
            z-index:10;
        }

        .sidebar-header{
            display:flex;
            align-items:center;
            gap:10px;
            padding:20px 18px;
        }

        .sidebar-header .mark{
            width:30px; height:30px;
            border-radius:9px 9px 9px 3px;
            background:linear-gradient(135deg, var(--accent), var(--accent-2));
            display:flex; align-items:center; justify-content:center;
            font-size:15px; font-weight:700;
        }

        .sidebar-header span{
            font-weight:700;
            font-size:16px;
        }

        .sidebar ul{
            list-style:none;
            margin-top:10px;
            padding:0 10px;
            flex:1;
        }

        .sidebar ul li a{
            color:#a7abc2;
            text-decoration:none;
            display:flex;
            align-items:center;
            gap:11px;
            padding:10px 12px;
            border-radius:10px;
            font-size:13.5px;
            font-weight:500;
            transition:.15s;
        }

        .sidebar ul li a i{ font-size:15px; width:16px; text-align:center; }

        .sidebar ul li a:hover{
            background:var(--panel-2);
            color:#fff;
        }

        .sidebar ul li a.active{
            background:var(--accent);
            color:#fff;
        }

        .sidebar-foot{
            padding:14px 18px 20px;
            border-top:1px solid rgba(255,255,255,.08);
            font-size:11.5px;
            color:#6a6e85;
        }

        /* ---------- Content ---------- */
        .content{
            margin-left:196px;
            transition:margin-left .25s ease;
        }

        .topbar{
            background:var(--card);
            padding:14px 26px;
            display:flex;
            align-items:center;
            justify-content:space-between;
            border-bottom:1px solid var(--line);
            position:sticky; top:0; z-index:5;
        }

        .menu-btn{
            font-size:21px;
            cursor:pointer;
            color:var(--ink);
            display:flex;
        }

        .topbar-title{ font-weight:600; font-size:15px; }

        .topbar-right{ display:flex; align-items:center; gap:14px; }

        .bell{
            width:34px; height:34px;
            border-radius:10px;
            background:var(--accent-soft);
            display:flex; align-items:center; justify-content:center;
            color:var(--accent);
            font-size:15px;
            position:relative;
        }

        .bell .dot{
            position:absolute; top:7px; right:8px;
            width:6px; height:6px; border-radius:50%;
            background:var(--accent-2);
        }

        .topbar-avatar{
            width:34px; height:34px;
            border-radius:50%;
            object-fit:cover;
        }

        .dashboard-body{ padding:22px 26px 30px; }

        /* ---------- Cards ---------- */
        .card{
            background:var(--card);
            border:1px solid var(--line);
            border-radius:var(--radius);
            box-shadow:0 1px 2px rgba(20,22,40,.03);
        }

        .row{ display:flex; flex-wrap:wrap; gap:18px; align-items:flex-start; }

        /* Profile card */
        .profile-card{
            width:280px;
            flex:none;
            padding:26px 20px;
            text-align:center;
        }

        .avatar-ring{
            width:78px; height:78px;
            margin:0 auto 14px;
            border-radius:50%;
            padding:3px;
            background:linear-gradient(135deg, var(--accent), var(--accent-2));
            position:relative;
        }

        .avatar-ring img{
            width:100%; height:100%;
            border-radius:50%;
            object-fit:cover;
            border:2.5px solid var(--card);
            display:block;
        }

        .avatar-ring .status{
            position:absolute; bottom:2px; right:2px;
            width:14px; height:14px;
            border-radius:50%;
            background:var(--ok);
            border:2.5px solid var(--card);
        }

        .profile-card h4{ font-size:16px; margin-bottom:2px; }
        .profile-card p{ color:var(--muted); font-size:12.5px; }

        .profile-tags{
            display:flex; justify-content:center; gap:8px;
            margin-top:16px;
        }

        .profile-tags span{
            font-size:11px;
            font-weight:600;
            padding:5px 10px;
            border-radius:20px;
            background:var(--accent-soft);
            color:var(--accent);
        }

        /* Welcome card */
        .welcome-card{
            flex:1;
            padding:20px;
            display:flex;
            gap:20px;
            min-height:560px;
        }

        .welcome-card h3{ font-size:19px; }
        .welcome-card .sub{
            color:var(--muted);
            margin-top:6px;
            font-size:13px;
            line-height:1.55;
            max-width:46ch;
        }

        /* Signature stat row -- chat-bubble shaped */
        .stat-row{
            display:flex; gap:12px;
            margin-top:20px;
            flex-wrap:wrap;
        }

        .bubble-stat{
            flex:1 1 120px;
            padding:16px 16px 14px;
            border-radius:16px 16px 16px 4px;
            color:#fff;
            position:relative;
            overflow:hidden;
        }

        .bubble-stat::after{
            content:"";
            position:absolute;
            width:60px; height:60px;
            border-radius:50%;
            background:rgba(255,255,255,.12);
            top:-20px; right:-20px;
        }

        .bubble-stat h4{ font-size:24px; }
        .bubble-stat p{ font-size:11.5px; opacity:.85; margin-top:2px; }
        .bubble-stat i{ font-size:14px; opacity:.9; }

        .bubble-stat.b1{ background:linear-gradient(135deg,#5b6bf6,#4453d6); }
        .bubble-stat.b2{ background:linear-gradient(135deg,#2fbf85,#1f9c6c); }
        .bubble-stat.b3{ background:linear-gradient(135deg,#ff7a5c,#f0553a); }

        /* Collapsed sidebar */
        .sidebar.hide{ margin-left:-196px; }
        .content.full{ margin-left:0; }

        @media (max-width:576px){
            .dashboard-body{ padding:16px; }
            .topbar{ padding:12px 16px; }
        }
    </style>
</head>

<body>

<div class="sidebar" id="sidebar">

    <div class="sidebar-header">
        <div class="mark">C</div>
        <span>Chat App</span>
    </div>

    <ul>
        <li><a href="/dashboard" class="active"><i class="bi bi-grid-1x2-fill"></i>Dashboard</a></li>
        <li><a href="/logout"><i class="bi bi-box-arrow-right"></i>Logout</a></li>
    </ul>

    <div class="sidebar-foot">Chat App &copy; 2026</div>

</div>


<div class="content" id="content">

    <div class="topbar">

        <div style="display:flex; align-items:center; gap:16px;">
            <i class="bi bi-list menu-btn" onclick="toggleMenu()"></i>
            <span class="topbar-title">Dashboard</span>
        </div>

        <div class="topbar-right">
            <div class="bell"><i class="bi bi-bell-fill"></i><span class="dot"></span></div>
            <img class="topbar-avatar" src="/<%= user.image %>" alt="">
        </div>

    </div>

    <div class="dashboard-body">

        <div class="row">

            <div style="width:300px;display:flex;flex-direction:column;gap:18px;">

            <div class="card profile-card">

                <div class="avatar-ring">
                    <img src="/<%= user.image %>" alt="Profile">
                    <div class="status"></div>
                </div>

                <h4><%= user.name %></h4>
                <p><%= user.email %></p>

                <div class="profile-tags">
                    <span>Online</span>
                </div>

            </div>

            <div class="card" style="padding:18px;max-height:360px;overflow-y:auto;">
                <h4 style="margin-bottom:16px;">Chats</h4>

                <% users.forEach(function(u){ %>
                    <div onclick="location.href='/chat/<%= u._id %>'" style="display:flex;align-items:center;gap:12px;padding:12px;border-radius:12px;cursor:pointer;transition:.2s;margin-bottom:8px;">
                        <img src="/<%= u.image %>" style="width:50px;height:50px;border-radius:50%;object-fit:cover;">
                        <div>
                            <div style="font-weight:600;"><%= u.name %></div>
                            <small style="color:var(--muted);">Tap to chat</small>
                        </div>
                    </div>
                <% }) %>
            </div>
            </div>

            <div class="card welcome-card">
                <div style="width:100%;display:flex;flex-direction:column;height:100%;">

                    <div style="padding:18px;border-bottom:1px solid var(--line);display:flex;align-items:center;gap:12px;">
                        <i class="bi bi-chat-dots-fill" style="font-size:22px;color:var(--accent);"></i>
                        <h3 style="margin:0;">Chat Window</h3>
                    </div>

                    <div style="flex:1;display:flex;justify-content:center;align-items:center;color:var(--muted);font-size:18px;">
                        Select a user from the left to start chatting.
                    </div>

                </div>
            </div>

        </div>

    </div>

</div>

<script>
function toggleMenu(){
    document.getElementById("sidebar").classList.toggle("hide");
    document.getElementById("content").classList.toggle("full");
}
</script>

</body>
</html>
