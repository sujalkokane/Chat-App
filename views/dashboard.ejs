<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
<script src="/socket.io/socket.io.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root{
            --ink:#171923;
            --panel:#1b1e2b;
            --panel-2:#22263a;
            --panel-line:rgba(255,255,255,.08);
            --bg:#f3f4f8;
            --card:#ffffff;
            --line:#e9eaf2;
            --muted:#8b8fa3;
            --muted-dark:#7c8098;
            --accent:#5b6bf6;
            --accent-2:#ff7a5c;
            --accent-soft:#eef0fe;
            --ok:#2fbf85;
            --radius:16px;
            --surface:#fafbff;
            --shadow:0 10px 30px rgba(20,24,40,.08);
        }

        *{ margin:0; padding:0; box-sizing:border-box; }

        body{
            background:linear-gradient(135deg,#eef2ff,#f8f9fc);
            font-family:'Inter',sans-serif;
            color:var(--ink);
            overflow-x:hidden;
            font-size:14px;
        }

        h1,h2,h3,h4{ font-family:'Space Grotesk',sans-serif; letter-spacing:-0.01em; }

        /* ---------- Sidebar (now the chat list) ---------- */
        .sidebar{
            width:290px;
            height:100vh;
            position:fixed;
            left:0; top:0;
            background:var(--panel);
            color:#fff;
            display:flex;
            flex-direction:column;
            transition:margin-left .25s ease;
            z-index:10;
            box-shadow:6px 0 24px rgba(0,0,0,.08);
        }

        .sidebar-header{
            display:flex;
            align-items:center;
            gap:10px;
            padding:20px 18px;
            border-bottom:1px solid var(--panel-line);
            flex-shrink:0;
        }

        .sidebar-header .mark{
            width:30px; height:30px;
            border-radius:9px 9px 9px 3px;
            background:linear-gradient(135deg, var(--accent), var(--accent-2));
            display:flex; align-items:center; justify-content:center;
            font-size:15px; font-weight:700;
            flex-shrink:0;
        }

        .sidebar-header span{
            font-weight:700;
            font-size:16px;
        }

        /* Scrollable chat/user list */
        .chat-list{
            flex:1;
            overflow-y:auto;
            padding:12px 10px;
        }

        .chat-list-label{
            font-size:11px;
            font-weight:700;
            text-transform:uppercase;
            letter-spacing:.06em;
            color:var(--muted-dark);
            padding:6px 10px 10px;
        }

        .chat-list-item{
            display:flex;
            align-items:center;
            gap:12px;
            padding:10px;
            border-radius:12px;
            cursor:pointer;
            transition:.15s;
            margin-bottom:4px;
        }

        .chat-list-item:hover{
            background:#313751;
            transform:translateX(4px);
        }

        .chat-list-item.active{
            background:linear-gradient(135deg,#5b6bf6,#7380ff);
            box-shadow:0 8px 20px rgba(91,107,246,.35);
        }

        .chat-list-item .avatar-wrap{
            position:relative;
            width:44px; height:44px;
            flex-shrink:0;
        }

        .chat-list-item .avatar-wrap img{
            width:44px; height:44px;
            border-radius:50%;
            object-fit:cover;
            display:block;
        }

        .chat-list-item .avatar-wrap .dot{
            position:absolute; bottom:1px; right:1px;
            width:11px; height:11px;
            border:2px solid var(--panel);
            border-radius:50%;
        }

        .chat-list-item .name{
            font-weight:600;
            font-size:13.5px;
            color:#fff;
        }

        .chat-list-item .sub{
            font-size:11.5px;
            color:var(--muted-dark);
            margin-top:1px;
        }

        .chat-list-item.active .sub{
            color:rgba(255,255,255,.75);
        }

        /* Bottom of sidebar: my profile, then logout below it */
        .sidebar-footer{
            border-top:1px solid var(--panel-line);
            padding:14px 16px 16px;
            flex-shrink:0;
        }

        .sidebar-footer .me{
            display:flex;
            align-items:center;
            gap:10px;
            padding:6px 4px 12px;
        }

        .sidebar-footer .me img{
            width:38px; height:38px;
            border-radius:50%;
            object-fit:cover;
            flex-shrink:0;
        }

        .sidebar-footer .me .name{
            font-weight:600;
            font-size:13.5px;
            color:#fff;
            white-space:nowrap;
            overflow:hidden;
            text-overflow:ellipsis;
            max-width:150px;
        }

        .sidebar-footer .me .status{
            font-size:11.5px;
            color:var(--ok);
            display:flex;
            align-items:center;
            gap:5px;
            margin-top:2px;
        }

        .sidebar-footer .me .status::before{
            content:"";
            width:6px; height:6px;
            border-radius:50%;
            background:var(--ok);
        }

        .logout-btn{
            display:flex;
            align-items:center;
            justify-content:center;
            gap:8px;
            width:100%;
            padding:10px;
            border-radius:10px;
            background:var(--panel-2);
            color:#e2536a;
            text-decoration:none;
            font-weight:600;
            font-size:13px;
            transition:.15s;
        }

        .logout-btn:hover{
            background:#2a2438;
        }

        /* ---------- Content (now just the chat area) ---------- */
        .content{
            margin-left:290px;
            transition:margin-left .25s ease;
            height:100vh;
            display:flex;
            flex-direction:column;
            background:var(--surface);
        }

        .topbar{
            background:var(--card);
            padding:14px 26px;
            display:flex;
            align-items:center;
            justify-content:space-between;
            border-bottom:1px solid var(--line);
            flex-shrink:0;
        }

        .menu-btn{
            font-size:21px;
            cursor:pointer;
            color:var(--ink);
            display:flex;
        }

        .topbar-title{ font-weight:600; font-size:15px; }

        .topbar-right{ display:flex; align-items:center; gap:14px; }

        .bell{
            width:34px; height:34px;
            border-radius:10px;
            background:var(--accent-soft);
            display:flex; align-items:center; justify-content:center;
            color:var(--accent);
            font-size:15px;
            position:relative;
        }

        .bell .dot{
            position:absolute; top:7px; right:8px;
            width:6px; height:6px; border-radius:50%;
            background:var(--accent-2);
        }

        /* Chat section fills the entire right side */
        .chat-section{
            flex:1;
            display:flex;
            flex-direction:column;
            min-height:0;
            overflow:hidden;
        }

        .chat-header{
            background:#fff;
            border-bottom:1px solid var(--line);
            flex-shrink:0;
        }

        .chat-body{
            flex:1;
            display:flex;
            flex-direction:column;
            justify-content:flex-start;
            align-items:stretch;
            padding:20px 26px;
            overflow-y:auto;
            background:#f5f7fc;
        }

        .chat-empty{
            display:flex;
            justify-content:center;
            align-items:center;
            color:var(--muted);
            font-size:16px;
            text-align:center;
        }

        .msg-row{
            display:flex;
            width:100%;
            margin-top:12px;
        }
        .msg-row:first-child{ margin-top:0; }

        .msg-row.left{ justify-content:flex-start; }
        .msg-row.right{ justify-content:flex-end; }

        .msg-bubble{
            max-width:60%;
            padding:10px 14px;
            font-size:13.5px;
            line-height:1.4;
            word-wrap:break-word;
        }

        .msg-bubble.mine{
            background:var(--accent);
            color:#fff;
            border-radius:16px 16px 16px 4px;
        }

        .msg-bubble.theirs{
            background:#fff;
            color:var(--ink);
            border-radius:16px 16px 4px 16px;
            box-shadow:0 1px 2px rgba(0,0,0,.08);
        }

        .msg-time{
            font-size:10px;
            opacity:.65;
            margin-top:6px;
            text-align:right;
        }

        .empty-state{
            margin:auto;
            text-align:center;
            color:var(--muted);
        }
        .empty-state i{
            font-size:64px;
            color:#c5cae8;
            margin-bottom:14px;
        }
        .empty-state h3{
            margin-bottom:8px;
        }

        .chat-input-bar{
            display:flex;
            align-items:center;
            gap:12px;
            padding:14px 26px;
            background:#fff;
            border-top:1px solid var(--line);
            flex-shrink:0;
        }

        .chat-input-bar input{
            flex:1;
            border:none;
            outline:none;
            background:#f1f3f9;
            border-radius:24px;
            padding:14px 18px;
            font-size:14px;
            transition:.2s;
            border:2px solid transparent;
        }

        .chat-input-bar input:focus{
            border-color:#d6dcff;
            background:#fff;
        }

        .chat-input-bar button{
            width:52px;
            height:52px;
            border:none;
            border-radius:50%;
            background:var(--accent);
            color:#fff;
            font-size:16px;
            cursor:pointer;
            flex-shrink:0;
        }

        /* Collapsed sidebar */
        .sidebar.hide{ margin-left:-290px; }
        .content.full{ margin-left:0; }

        @media (max-width:768px){
            .sidebar{ width:260px; }
            .content{ margin-left:260px; }
            .sidebar.hide{ margin-left:-260px; }
            .chat-body{ padding:16px; }
            .chat-input-bar{ padding:12px 16px; }
        }
    </style>
</head>

<body>

<div class="sidebar" id="sidebar">

    <div class="sidebar-header">
        <div class="mark">C</div>
        <span>Chat App</span>
    </div>

    <div class="chat-list" id="chat-list">
        <div class="chat-list-label">Chats</div>

        <% users.forEach(function(u){ %>
            <div
                class="chat-list-item"
                id="chat-item-<%= u._id %>"
                onclick="openChat('<%= u._id %>','<%= u.name %>','/<%= u.image %>', '<%= u.isOnline %>')">
                <div class="avatar-wrap">
                    <img src="/<%= u.image %>">
                    <span
                        id="status-<%= u._id %>"
                        class="dot"
                        style="background:<%= u.isOnline == '1' ? '#2fbf85' : '#5c6079' %>;">
                    </span>
                </div>
                <div>
                    <div style="display:flex;align-items:center;gap:8px;">
                        <div class="name"><%= u.name %></div>
                        <span id="unread-<%= u._id %>" style="display:none;width:10px;height:10px;border-radius:50%;background:#ff4d4f;flex-shrink:0;"></span>
                    </div>
                    <div class="sub">Tap to chat</div>
                </div>
            </div>
        <% }) %>
    </div>

    <div class="sidebar-footer">
        <div class="me">
            <img src="/<%= user.image %>" alt="">
            <div>
                <div class="name"><%= user.name %></div>
                <div class="status">Online</div>
            </div>
        </div>
        <a href="#" id="logoutBtn" class="logout-btn">
            <i class="bi bi-box-arrow-right"></i> Logout
        </a>
    </div>

</div>


<div class="content" id="content">

    <div class="topbar">
        <div style="display:flex; align-items:center; gap:16px;">
            <i class="bi bi-list menu-btn" onclick="toggleMenu()"></i>
            <span class="topbar-title">Messages</span>
        </div>

        <div class="topbar-right">
            <div class="bell"><i class="bi bi-bell-fill"></i><span class="dot"></span></div>
        </div>
    </div>

    <div class="chat-section">

        <div id="chat-header" class="chat-header" style="display:none;padding:16px 26px;align-items:center;gap:12px;">
            <img id="chat-user-image" src="https://via.placeholder.com/44" style="width:52px;height:52px;border-radius:50%;object-fit:cover;">
            <div style="flex:1;">
                <div id="chat-user-name" style="font-weight:600;">Select a user</div>
                <small id="chat-user-status" style="color:#2fbf85;">Offline</small>
            </div>
        </div>

        <div id="chat-box" class="chat-body chat-empty">
            <div class="empty-state">
                <i class="bi bi-chat-square-heart"></i>
                <h3>Select a conversation</h3>
                <p>Choose a contact from the left to start messaging.</p>
            </div>
        </div>

        <div id="chat-input" class="chat-input-bar" style="display:none;">
            <input
                id="message"
                type="text"
                placeholder="Type a message...">
            <button id="send-btn">
                <i class="bi bi-send-fill"></i>
            </button>
        </div>

    </div>

</div>

<script>
let receiver_id = "";

function toggleMenu(){
    document.getElementById("sidebar").classList.toggle("hide");
    document.getElementById("content").classList.toggle("full");
}

// Builds a single message row+bubble and appends it to the chat box
function appendMessage(chatBox, message, isMine){
    const row = document.createElement('div');
    row.className = 'msg-row ' + (isMine ? 'left' : 'right');

    const bubble = document.createElement('div');
    bubble.className = 'msg-bubble ' + (isMine ? 'mine' : 'theirs');
    bubble.textContent = message; // textContent avoids HTML/script injection

    row.appendChild(bubble);
    chatBox.appendChild(row);
}

function setActiveChatItem(id){
    document.querySelectorAll('.chat-list-item').forEach(el => el.classList.remove('active'));
    const el = document.getElementById('chat-item-' + id);
    if (el) el.classList.add('active');
}

function openChat(id, name, image, isOnline) {
    receiver_id = id;
    const unreadDot = document.getElementById('unread-' + id);
    if (unreadDot) {
        unreadDot.style.display = 'none';
    }
    setActiveChatItem(id);

    document.getElementById('chat-header').style.display = 'flex';
    document.getElementById('chat-input').style.display = 'flex';

    const chatBox = document.getElementById('chat-box');
    chatBox.classList.remove('chat-empty'); // remove centering placeholder styles
    chatBox.innerHTML = '';

    document.getElementById('chat-user-name').innerText = name;
    document.getElementById('chat-user-image').src = image;
    const status = document.getElementById('chat-user-status');
    status.innerText = isOnline === '1' ? 'Online' : 'Offline';
    status.style.color = isOnline === '1' ? '#2fbf85' : '#888';

    fetch('/load-chat', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            sender: sender_id,
            receiver: receiver_id
        })
    })
    .then(res => res.json())
    .then(data => {
        console.log('load-chat response:', data);
        chatBox.innerHTML = '';

        const chats = data.chats || data.data || [];

        chats.forEach(chat => {
            const sender = String(chat.sender || chat.sender_id);
            const isMine = sender === String(sender_id);
            appendMessage(chatBox, chat.message, isMine);
        });

        if (chats.length === 0) {
            chatBox.innerHTML = '<div style="margin:auto;color:#8b8fa3">No messages yet. Start the conversation!</div>';
        }

        chatBox.scrollTop = chatBox.scrollHeight;
    })
    .catch(err => console.error(err));
}
</script>
<script>
// Save chat when Send is clicked
document.getElementById('send-btn').addEventListener('click', function () {
    const message = document.getElementById('message').value.trim();

    if (!message) return;

    if (!receiver_id) {
        alert('Please select a user first.');
        return;
    }

    socket.emit('new-chat', {
        sender: sender_id,
        receiver: receiver_id,
        message: message
    });

    document.getElementById('message').value = '';
});

// Allow pressing Enter to send
document.getElementById('message').addEventListener('keydown', function(e){
    if (e.key === 'Enter') {
        document.getElementById('send-btn').click();
    }
});
</script>
<script>
// Disconnect socket before logging out
const logoutBtn = document.getElementById('logoutBtn');

logoutBtn.addEventListener('click', function (e) {
    e.preventDefault();

    socket.disconnect();

    setTimeout(() => {
        window.location.href = '/logout';
    }, 100);
});
</script>
<script>
    var sender_id = '<%= user._id %>';
   const socket = io("/user-namespace", {
  query: {
    token: sender_id
  }
});

// Listen for users coming online
socket.on('online-user', function(data) {
    const statusElement = document.getElementById('status-' + data.userId);
    if (statusElement) {
        statusElement.style.background = '#2fbf85';
    }
    if (String(receiver_id) === String(data.userId)) {
        const chatStatus = document.getElementById('chat-user-status');
        chatStatus.innerText = 'Online';
        chatStatus.style.color = '#2fbf85';
    }
});

// Listen for users going offline
socket.on('offline-user', function(data) {
    const statusElement = document.getElementById('status-' + data.userId);
    if (statusElement) {
        statusElement.style.background = '#5c6079';
    }
    if (String(receiver_id) === String(data.userId)) {
        const chatStatus = document.getElementById('chat-user-status');
        chatStatus.innerText = 'Offline';
        chatStatus.style.color = '#888';
    }
});

// Receive new chats in real time
socket.on('load-new-chat', function (data) {
    const chatBox = document.getElementById('chat-box');
    const sender = String(data.sender || data.sender_id);
    const receiver = String(data.receiver || data.receiver_id);

    // Show unread indicator if a message arrives from a user whose chat isn't open
    if (receiver === String(sender_id) && sender !== String(receiver_id)) {
        const dot = document.getElementById('unread-' + sender);
        if (dot) {
            dot.style.display = 'inline-block';
        }
    }

    if (!((sender === sender_id && receiver === receiver_id) ||
          (sender === receiver_id && receiver === sender_id))) {
        return;
    }

    chatBox.classList.remove('chat-empty');
    const isMine = sender === sender_id;
    appendMessage(chatBox, data.message, isMine);

    chatBox.scrollTop = chatBox.scrollHeight;
});

</script>
</body>
</html>